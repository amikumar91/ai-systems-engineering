{
  "permissions": {
    "allow": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git push *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git pull *)",
      "Bash(gh *)",
      "Bash(find topics *)",
      "Bash(find assets *)",
      "Bash(find .claude *)",
      "Bash(curl -L *)",
      "Bash(mkdir -p *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(wc -l *)",
      "Bash(python3 *)",
      "Bash(python *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(npm run *)",
      "Bash(npm install *)",
      "Bash(npm i *)",
      "Bash(node *)",
      "PowerShell(git *)",
      "PowerShell(gh *)",
      "PowerShell(npm *)",
      "PowerShell(node *)",
      "PowerShell(New-Item *)",
      "PowerShell(Remove-Item *)",
      "PowerShell(Get-ChildItem *)",
      "PowerShell(Get-Content *)",
      "PowerShell(Rename-Item *)",
      "PowerShell(Get-Command *)",
      "PowerShell(Write-Host *)",
      "PowerShell(Select-String *)",
      "Write(topics/*)",
      "Write(topics/*/*)",
      "Write(topics/*/*/*)",
      "Write(assets/*)",
      "Write(assets/images/topics/*/*)",
      "Write(.claude/agents/*)",
      "Write(.claude/commands/*)",
      "Write(demos/*)",
      "Write(demos/*/*)",
      "Edit(topics/*)",
      "Edit(topics/*/*)",
      "Edit(topics/*/*/*)",
      "Edit(README.md)",
      "Edit(AGENTS.md)",
      "Edit(topics/*/README.md)",
      "Edit(.claude/agents/*)",
      "Edit(.claude/commands/*)",
      "Edit(.claude/settings.json)",
      "Edit(demos/*)",
      "Edit(demos/*/*)",
      "Edit(docusaurus.config.js)",
      "Edit(sidebars.js)",
      "WebSearch(*)",
      "WebFetch(*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "PowerShell(Remove-Item -Recurse -Force *)"
    ]
  },
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@github/github-mcp-server"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    }
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Session complete. Run /discover-topics periodically to keep the catalog current.'"
          }
        ]
      }
    ]
  }
}
