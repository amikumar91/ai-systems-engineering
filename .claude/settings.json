{
  "permissions": {
    "allow": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(find topics *)",
      "Bash(find assets *)",
      "Bash(find .claude *)",
      "Bash(curl -L *)",
      "Bash(mkdir -p *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(wc -l *)",
      "Bash(python3 *)",
      "Bash(python *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Write(topics/*)",
      "Write(topics/*/*)",
      "Write(assets/*)",
      "Write(assets/images/topics/*/*)",
      "Write(.claude/agents/*)",
      "Write(.claude/commands/*)",
      "Write(demos/*)",
      "Write(demos/*/*)",
      "Edit(topics/*)",
      "Edit(topics/*/*)",
      "Edit(README.md)",
      "Edit(topics/*/README.md)",
      "Edit(.claude/agents/*)",
      "Edit(.claude/commands/*)",
      "Edit(.claude/settings.json)",
      "WebSearch(*)",
      "WebFetch(*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)"
    ]
  },
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@github/github-mcp-server"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    }
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Session complete. Run /discover-topics periodically to keep the catalog current.'"
          }
        ]
      }
    ]
  }
}
