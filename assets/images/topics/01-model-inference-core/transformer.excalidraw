      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "middle",
      "baseline": 11,
      "containerId": null,
      "originalText": "All modern LLMs use decoder-only. Encoder-only survives for embeddings and classification. Encoder-decoder survives for translation and summarization.",
