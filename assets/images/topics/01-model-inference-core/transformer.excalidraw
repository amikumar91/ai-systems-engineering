      "roundness": null,
      "seed": 170,
      "version": 1,
      "versionNonce": 170,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1716000000000,
      "link": null,
      "locked": false,
      "text": "Token embeddings + positional encoding  ·  Multi-head (self-)attention  ·  Feed-forward network (FFN)  ·  Residual connections  ·  Layer normalization\nKey difference: attention MASK — encoder sees all positions (bidirectional), decoder sees only past positions (causal/triangular mask)\nFFN holds ~2/3 of parameters  ·  Modern LLMs use RMSNorm (faster) and SwiGLU/SiLU activation instead of original LayerNorm + ReLU",
      "fontSize": 11,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 10,
      "containerId": null,
      "originalText": "Token embeddings + positional encoding  ·  Multi-head (self-)attention  ·  Feed-forward network (FFN)  ·  Residual connections  ·  Layer normalization\nKey difference: attention MASK — encoder sees all positions (bidirectional), decoder sees only past positions (causal/triangular mask)\nFFN holds ~2/3 of parameters  ·  Modern LLMs use RMSNorm (faster) and SwiGLU/SiLU activation instead of original LayerNorm + ReLU",
      "lineHeight": 1.25
    },
